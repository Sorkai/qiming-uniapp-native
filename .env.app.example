# App offline H5 build. Keep paths relative so uni-app web-view can load files
# from native-app/src/hybrid/html inside Android/iOS packages.
VITE_PUBLIC_PATH = ./
VITE_API_URL = https://example.com
VITE_ROUTER_HISTORY = "hash"
VITE_CDN = false
VITE_COMPRESSION = "none"
VITE_DOCMEE_API_KEY = ""
VITE_DOCMEE_CONTAINER_ID = ""
