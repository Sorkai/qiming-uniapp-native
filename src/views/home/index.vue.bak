      }

      .el-icon--right {
        font-size: 18px;
        font-weight: bold;
        color: #666;
        transition: transform 0.3s ease;
      }
    }
  }
}

.banner {
  position: relative;
  height: 100vh;
  margin-top: 0;

  .hero-particles {
    position: absolute;
    inset: 0;
    z-index: 2;
    overflow: hidden;
    pointer-events: none;

    .particle {
      position: absolute;
      background: rgba(255, 255, 255, 0.3);
      border-radius: 50%;
      animation: floatParticle linear infinite;
    }
  }

  :deep(.el-carousel),
  :deep(.el-carousel__container) {
    height: 100vh;
  }

  :deep(.el-carousel__item) {
    overflow: hidden;
  }
}

@keyframes floatParticle {
  0% {
    transform: translateY(100vh) rotate(0deg);
    opacity: 0;
  }
  10% {
    opacity: 1;
  }
  90% {
    opacity: 1;
  }
  100% {
    transform: translateY(-100px) rotate(720deg);
    opacity: 0;
  }
}

.carousel-content {
  display: flex;
  align-items: center;
  height: 100%;
  background-repeat: no-repeat;
  background-position: center;
  background-size: cover;

  &::before {
    position: absolute;
    inset: 0;
    content: "";
    background: linear-gradient(135deg, rgba(0,0,0,0.6) 0%, rgba(0,0,0,0.3) 100%);
  }

  .carousel-text {
    position: relative;
    z-index: 3;
    max-width: 800px;
    padding: 0 80px;
    color: #fff;
    user-select: none;

    .hero-badge {
      display: inline-block;
      padding: 8px 20px;
      margin-bottom: 24px;
      font-size: 14px;
      font-weight: 500;
      color: #fff;
      background: rgba(255, 255, 255, 0.15);
      backdrop-filter: blur(10px);
      border: 1px solid rgba(255, 255, 255, 0.2);
      border-radius: 30px;
    }

    .main-title {
      margin: 0 0 16px;
      font-size: 72px;
      font-weight: 800;
      line-height: 1.1;
      color: #fff;
      text-shadow: 0 4px 20px rgb(0 0 0 / 30%);
    }

    .sub-title {
      margin: 0 0 20px;
      font-size: 48px;
      font-weight: 700;
      line-height: 1.2;
      color: #ffd700;
      text-shadow: 0 2px 10px rgb(0 0 0 / 30%);
    }

    .hero-desc {
      margin: 0 0 32px;
      font-size: 18px;
      line-height: 1.8;
      color: rgba(255, 255, 255, 0.9);
    }

    .hero-buttons {
      display: flex;
      gap: 16px;

      .hero-btn {
        height: 52px;
        padding: 0 36px;
        font-size: 16px;
        font-weight: 600;
        border-radius: 26px;
        transition: all 0.3s;

        &.primary {
          color: #fff;
          background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
          border: none;

          &:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 30px rgb(102 126 234 / 50%);
          }
        }

        &.secondary {
          color: #fff;
          background: transparent;
          border: 2px solid rgba(255, 255, 255, 0.5);

          &:hover {
            background: rgba(255, 255, 255, 0.1);
            border-color: #fff;
          }
        }
      }
    }
  }
}

.scroll-hint {
  position: absolute;
  bottom: 40px;
  left: 50%;
  z-index: 10;
  font-size: 14px;
  color: #fff;
  text-align: center;
  user-select: none;
  transform: translateX(-50%);

  span {
    display: block;
    margin-bottom: 8px;
    text-shadow: 0 2px 4px rgb(0 0 0 / 30%);
  }

  .scroll-arrow {
    .el-icon {
      font-size: 24px;
      color: #fff;

      &.animated {
        animation: bounce 2s infinite;
      }
    }
  }
}

@keyframes bounce {
  0%, 20%, 50%, 80%, 100% {
    transform: translateY(0);
  }
  40% {
    transform: translateY(-10px);
  }
  60% {
    transform: translateY(-5px);
  }
}

// 统计数据区域
.stats-section {
