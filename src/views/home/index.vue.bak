// 平台特色
.platform-intro {
  padding: 120px 0;
  background: linear-gradient(180deg, #f8f9fa 0%, #fff 100%);

  .feature-list {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
  }

  .feature-item {
    position: relative;
    overflow: hidden;
    border-radius: 20px;
    box-shadow: 0 10px 40px rgb(0 0 0 / 10%);
    transition: all 0.4s;

    &:hover {
      transform: translateY(-10px);
      box-shadow: 0 20px 60px rgb(0 0 0 / 15%);

      .feature-image img {
        transform: scale(1.1);
      }

      .feature-overlay {
        opacity: 1;
      }
    }

    a {
      display: block;
      text-decoration: none;
    }

    .feature-image {
      aspect-ratio: 4/3;
      overflow: hidden;

      img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.6s;
      }
    }

    .feature-overlay {
      position: absolute;
      inset: 0;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      padding: 30px;
      background: linear-gradient(180deg, transparent 0%, rgba(0,0,0,0.8) 100%);
