<script setup lang="ts">
import { ref, onMounted, onUnmounted, computed } from "vue";
import { useRouter } from "vue-router";
import {
  Monitor,
  Connection,
  Operation,
  ArrowDown,
  User,
  SwitchButton,
  Setting,
  Check
} from "@element-plus/icons-vue";
import LoginDialog from "@/components/LoginDialog.vue";
import { storageLocal } from "@pureadmin/utils";
import { userKey, removeToken, hasManageAccess } from "@/utils/auth";
import { ElMessage } from "element-plus";
import type { DataInfo } from "@/utils/auth";

// 导入图片资源
import banner1 from "@/assets/home/banner1.jpg";
import banner2 from "@/assets/home/banner2.jpg";
import card1 from "@/assets/home/card1.jpg";
import card2 from "@/assets/home/card2.jpg";
import card3 from "@/assets/home/card3.jpg";
import logo from "@/assets/logo.png";

const router = useRouter();
const isScrolled = ref(false);
const showLoginDialog = ref(false);
const userInfo = ref<DataInfo<number> | null>(storageLocal().getItem(userKey));

// 检查用户是否有管理权限（教师或管理员）
const hasAdminAccess = computed(() => {
  return hasManageAccess();
});

// 监听滚动事件
const handleScroll = () => {
  isScrolled.value = window.scrollY > 50;
};

onMounted(() => {
  window.addEventListener("scroll", handleScroll);
});

onUnmounted(() => {
  window.removeEventListener("scroll", handleScroll);
});

// 滚动到指定区域
const scrollToSection = (id: string) => {
  const element = document.getElementById(id);
  if (element) {
    element.scrollIntoView({ behavior: "smooth" });
  }
};

// 粒子样式
const getParticleStyle = (index: number) => {
  const size = Math.random() * 10 + 5;
  return {
    left: `${Math.random() * 100}%`,
    top: `${Math.random() * 100}%`,
    width: `${size}px`,
    height: `${size}px`,
    animationDelay: `${Math.random() * 5}s`,
    animationDuration: `${Math.random() * 10 + 10}s`
  };
};

// 轮播图数据
const carouselItems = ref([
  {
    title: "创新技术平台",
    subtitle: "全方位技术支持",
    description: "基于 Vue3 + TypeScript + Vite 构建，为企业提供高效稳定的数字化解决方案",
    background: banner1
  },
  {
    title: "智慧解决方案",
    subtitle: "助力企业转型",
    description: "完善的权限管理、丰富的组件库、灵活的架构设计，满足各类业务需求",
    background: banner2
  }
]);

// 统计数据
const statsData = ref([
  { icon: "👥", number: "50,000+", label: "注册用户" },
  { icon: "�", number: "1,000+", label: "企业客户" },
  { icon: "�", number: "200+", label: "功能组件" },
  { icon: "⭐", number: "15,000+", label: "GitHub Stars" }
]);

// 平台特性数据
const features = ref([
  {
    icon: "Monitor",
    title: "智能管理",
    description: "提供智能化的管理工具，AI 驱动的数据分析，提升工作效率",
    image: card1
  },
  {
    icon: "Connection",
    title: "协同办公",
    description: "多部门协同工作，实时通讯，信息共享无障碍",
    image: card2
  },
  {
    icon: "Operation",
    title: "数据分析",
    description: "强大的数据分析能力，可视化报表，助力科学决策",
    image: card3
  }
]);

// 核心服务
const services = ref([
  {
    icon: "�️",
    title: "定制开发",
    description: "根据企业需求提供专业的定制化开发服务",
    features: ["需求分析", "架构设计", "功能开发", "测试部署"]
  },
  {
    icon: "�",
    title: "技术支持",
    description: "7×24 小时专业技术支持，快速响应解决问题",
    features: ["在线咨询", "远程协助", "问题诊断", "性能优化"]
  },
  {
    icon: "�",
    title: "培训服务",
    description: "系统化的技术培训，助力团队快速上手",
    features: ["视频教程", "文档指南", "实战演练", "一对一指导"]
  },
  {
    icon: "�",
    title: "部署运维",
    description: "专业的部署方案和运维服务，确保系统稳定运行",
    features: ["环境搭建", "自动部署", "监控告警", "故障恢复"]
  }
]);

// 技术栈
const techStack = ref([
  { icon: "⚡", name: "Vue 3", version: "v3.5+" },
  { icon: "�", name: "TypeScript", version: "v5.0+" },
  { icon: "🚀", name: "Vite", version: "v6.0+" },
  { icon: "🎨", name: "Element Plus", version: "v2.10+" },
  { icon: "🍍", name: "Pinia", version: "v3.0+" },
  { icon: "🌊", name: "Tailwind CSS", version: "v4.0+" },
  { icon: "�", name: "pnpm", version: "v10+" },
  { icon: "�", name: "权限管理", version: "RBAC" }
]);

// 客户评价
const testimonials = ref([
  {
    content: "Pure Admin 帮助我们快速搭建了企业级管理系统，节省了大量开发时间，代码质量非常高！",
    name: "张经理",
    title: "某科技公司 CTO",
    avatar: "张"
  },
  {
    content: "文档详尽，组件丰富，社区活跃。遇到问题都能快速得到解决，强烈推荐！",
    name: "李工程师",
    title: "全栈开发工程师",
    avatar: "李"
  },
  {
    content: "从 Vue2 迁移到 Vue3，Pure Admin 让这个过程变得非常顺畅，现代化的技术栈很棒！",
    name: "王总监",
    title: "技术总监",
    avatar: "王"
  }
]);

// 处理下拉菜单命令
const handleCommand = (command: string) => {
  switch (command) {
    case "space":
      // 检查用户权限，只允许教师和管理员进入空间
      if (hasAdminAccess.value) {
        router.push("/welcome/index");
      } else {
        ElMessage.warning("您没有权限进入后台管理空间");
      }
      break;
    case "account":
      router.push("/account");
      break;
    case "logout":
      removeToken();
      storageLocal().removeItem(userKey);
      userInfo.value = null;
      ElMessage.success("退出登录成功");
      break;
  }
};

// 登录成功处理
const handleLoginSuccess = () => {
  userInfo.value = storageLocal().getItem(userKey);
  showLoginDialog.value = false;
  // 刷新当前页面
  window.location.reload();
};
</script>

