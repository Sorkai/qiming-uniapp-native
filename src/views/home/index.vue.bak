      transition: opacity 0.3s;

      h3 {
        font-size: 24px;
        font-weight: 700;
        color: #fff;
        margin-bottom: 8px;
      }

      p {
        font-size: 14px;
        color: rgba(255, 255, 255, 0.8);
        margin: 0;
      }
    }
  }
}

